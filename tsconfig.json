{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true
  },
  "include": [
    "config/**/*.ts",
    "helper/**/*.ts",
    "page-objects/**/*.ts",
    "test-data/**/*.ts",
    "tests/**/*.ts",
    "api/**/*.ts",
    "grpc/**/*.ts",
    "mobile/**/*.ts"
  ]
}
