{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/*"],
      "@ui/*": ["ui/*"],
      "@api/*": ["api/*"],
      "@mobile/*": ["mobile/*"]
    }
  },
  "include": [
    "config/**/*.ts",
    "core/**/*.ts",
    "ui/**/*.ts",
    "api/**/*.ts",
    "mobile/**/*.ts",
    "performance/**/*.ts"
  ]
}
