# Copy this file to .env.sandbox / .env.uat / .env.<env> and fill in the
# values. `test_env=<env>` selects the file at runtime
# (cross-env test_env=sandbox playwright test ...).

# The app's sign-in / SSO URL.
AUTH_URL=https://auth.example.com/signin

# The app's post-login landing URL. Tests start from this URL with the
# saved storage state already loaded.
APP_URL=https://app.example.com

# Optional credential override. Defaults live in helper/authenticate-set-up.ts
# (which you should fill in per project). NEVER commit real credentials.
# APP_USER=
# APP_PASS=
