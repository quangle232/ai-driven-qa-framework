# Master reference of ALL keys. Per-env templates live alongside this file:
#   .env.dev.example · .env.test.example · .env.prod.example
# Copy the one you need to environments/.env.<env> (e.g. .env.test) and fill it
# in. `test_env=<env>` selects the file at runtime, e.g.:
#   cross-env test_env=prod playwright test ...   → loads environments/.env.prod
# Valid envs: dev | test | prod (default: test).

# The app's sign-in / SSO URL.
AUTH_URL=https://auth.example.com/signin

# The app's post-login landing URL. Tests start from this URL with the
# saved storage state already loaded.
APP_URL=https://app.example.com

# Optional credential override. Defaults live in helper/authenticate-set-up.ts
# (which you should fill in per project). NEVER commit real credentials.
# APP_USER=
# APP_PASS=

# ---- API testing (tests/api) ----------------------------------------------
# Base URL for the REST API under test. Falls back to APP_URL when unset.
# API_BASE_URL=https://api.example.com
# API_TOKEN=                       # optional bearer token for authed endpoints

# ---- gRPC testing (tests/grpc) --------------------------------------------
# Defaults target the in-process mock server, so tests run with no backend.
# GRPC_HOST=localhost
# GRPC_PORT=50051
# GRPC_TLS=false
# GRPC_TOKEN=                      # optional auth token sent as gRPC metadata

# ---- Mobile testing (tests/mobile) ----------------------------------------
# Native (Appium) is skip-gated unless ALLOW_MOBILE_NATIVE=1 is set.
# APPIUM_URL=http://127.0.0.1:4723
# MOBILE_PLATFORM=android          # android | ios
# DEVICE_GRID=local                # local | browserstack | saucelabs
# MOBILE_APP=                      # path / URL / cloud app id of the build
# Cloud grid creds (only when DEVICE_GRID is browserstack/saucelabs):
# BROWSERSTACK_USERNAME=
# BROWSERSTACK_ACCESS_KEY=
# SAUCE_USERNAME=
# SAUCE_ACCESS_KEY=
