# GitLab config for the qa-agent ship step — branch + merge request
# (.claude/skills/qa-agent/scripts/create-gitlab-mr.js, called by the
# qa-agent Phase 7.5 / gen-auto-test Phase 6 approval).
#
# 1. Copy this file to `.env.gitlab` in the same folder.
# 2. Create a project access token with the `api` scope:
#       GitLab → Project → Settings → Access tokens
# 3. Fill the values below. The real .env.gitlab is gitignored — never commit it.
#    Env vars with the same names take precedence over this file.

# Base URL of your GitLab instance (no trailing slash).
GITLAB_URL=https://gitlab.com
# Token with `api` scope (project or personal access token).
GITLAB_TOKEN=
# Numeric project id (Project → Settings → General) or URL-encoded path, e.g. group%2Fproject.
GITLAB_PROJECT_ID=
