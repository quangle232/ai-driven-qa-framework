# Git-hosting config for the qa-agent SHIP step — branch + merge/pull request
# (.claude/skills/qa-agent/scripts/create-mr.js, called by the qa-agent
# Phase 7.5 / gen-auto-test Phase 6 approval).
#
# 1. Copy this file to `.env.git` in the same folder.
# 2. Fill ONLY the section for your provider — the script auto-detects the
#    provider from the `origin` remote URL. Force it with GIT_PROVIDER (or
#    --provider) when the remote is an ssh host alias.
# 3. The real .env.git is gitignored — never commit it. Env vars with the
#    same names take precedence over this file.

# gitlab | github | bitbucket | azure | gitea  (empty = auto-detect)
GIT_PROVIDER=

## GitLab — token with `api` scope (Project → Settings → Access tokens)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
# Numeric id (Project → Settings → General) or URL-encoded path (group%2Fproject).
# Optional when the origin remote points at the project.
GITLAB_PROJECT_ID=

## GitHub — fine-grained PAT with "Pull requests: write" (or classic `repo` scope)
GITHUB_TOKEN=
# owner/repo — optional when the origin remote points at the repo.
GITHUB_REPO=
# GitHub Enterprise: https://<host>/api/v3
GITHUB_API_URL=https://api.github.com

## Bitbucket Cloud — access token (Bearer) OR username + app password (Basic)
BITBUCKET_TOKEN=
BITBUCKET_USER=
BITBUCKET_APP_PASSWORD=
# Optional when the origin remote points at the repo.
BITBUCKET_WORKSPACE=
BITBUCKET_REPO=

## Azure DevOps — PAT with "Code: Read & Write" (remote auto-detection not supported)
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/<org>
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_REPO=
AZURE_DEVOPS_PAT=

## Gitea / Forgejo — token from Settings → Applications
GITEA_URL=
GITEA_TOKEN=
# owner/repo — optional when the origin remote points at the repo.
GITEA_REPO=
