# DEV environment — copy to `environments/.env.dev` (gitignored) and fill in.
# Selected at runtime:  cross-env test_env=dev playwright test ...
# See .env.example for the full list of keys (API / gRPC / mobile).

AUTH_URL=https://auth.dev.example.com/signin
APP_URL=https://app.dev.example.com
